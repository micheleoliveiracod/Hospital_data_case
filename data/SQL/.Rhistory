install.packages(c("DBI", "RSQLite", "data.table"))
library(DBI)
library(RSQLite)
library(data.table)
#Criei uma conexão com um banco SQLite (arquivo local):
conexao <- dbConnect(SQLite(), dbname = "2table.sqlite") #escolhi o nome do arquivo antes de executar
library(readr)
appointments <- read_csv("C:/Users/miche/Projetos GitHub/Hospital_data_case/data/appointments.csv")
View(appointments)
library(readr)
treatments <- read_csv("C:/Users/miche/Projetos GitHub/Hospital_data_case/data/treatments.csv")
View(treatments)
dbWriteTable(conexao, "appointments", appointments, "treatments", treatments) #escolhi o nome da tabela que vai ser criada
#Encerre a conexão
dbDisconnect(conexao)
View(conexao)
